# Vercel Ignore - Don't upload these files/folders

# Dependencies (Vercel installs these)
node_modules

# Build output (Vercel builds on their servers)
.next
out
build

# Development files
.env.local
.env.development

# Test/Check files
check_models.*
pre-deploy-check.mjs
upgrade-super-admin.mjs

# Documentation (not needed for deployment)
*.md
!README.md

# Large document files
*.doc
*.docx
*.pdf

# Git
.git
.gitignore

# IDE
.vscode
.idea

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Testing
coverage
.nyc_output

# Misc
.vercel
